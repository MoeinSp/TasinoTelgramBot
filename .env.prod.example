# نمونه محیط پروداکشن برای دامین tasino.spayerx.ir
# کپی کن:  cp .env.prod.example .env.prod
# بعد مقادیر را پر کن. فایل .env.prod داخل image کپی نمی‌شود.

# ─── Django / عمومی ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=tasino.spayerx.ir,localhost,127.0.0.1

# ─── رمزر دیتابیس (باید با docker-compose DB_PASSWORD یکی باشد) ───────────────
# در شل سرور هم export کن یا در .env کنار compose بگذار:
#   DB_PASSWORD=strong-password
DB_PASSWORD=strong-password

# این دو تا در compose برای سرویس bot/migrate override می‌شوند؛
# اگر دستی ران می‌کنی همین‌ها را نگه دار:
DATABASE_URL=postgresql://tasino:strong-password@db:5432/tasino_db
BOT_REDIS_URL=redis://redis:6379/2

# ─── تلگرام ───────────────────────────────────────────────────────────────────
BOT_TOKEN=123456:ABCDEF-your-telegram-bot-token
USE_POLLING=false
WEBHOOK_HOST=https://tasino.spayerx.ir
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8443
WEBHOOK_SECRET=optional-long-secret

# پورت ادمین روی هاست (nginx → 127.0.0.1:8001)
ADMIN_PORT=8001
